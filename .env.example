GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_api_key_here
GOOGLE_MODEL=gemini-2.5-flash
# Optional: comma-separated fallback models for scripts/select_google_credential.py
GOOGLE_MODEL_CANDIDATES=gemini-flash-lite-latest,gemini-2.5-flash,gemini-2.5-flash-lite

# Tùy chọn: ghi đè URL agent card A2A
SEARCH_AGENT_CARD=http://localhost:8001/.well-known/agent-card.json
DATABASE_AGENT_CARD=http://localhost:8002/.well-known/agent-card.json
SYNTHESIS_AGENT_CARD=http://localhost:8003/.well-known/agent-card.json
